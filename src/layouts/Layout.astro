---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.tsx";
import RevealScript from "../components/RevealScript.astro";
import { ClientRouter } from "astro:transitions";
import { getLocaleFromUrl, t, type Locale } from "../i18n/utils";
import { buildSeo, organizationJsonLd, websiteJsonLd } from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  pagePath?: string;
  hideHeader?: boolean;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);

const title = Astro.props.title ?? tt("site.name");
const description = Astro.props.description ?? tt("site.description");
const pagePath = Astro.props.pagePath ?? Astro.url.pathname;

const seo = buildSeo({
  title,
  description,
  locale,
  path: pagePath,
});

const orgLd = organizationJsonLd();
const siteLd = websiteJsonLd(locale);
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={seo.canonical} />

    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:type" content={seo.ogType} />
    <meta property="og:locale" content={seo.ogLocale} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />

    <link rel="alternate" hreflang="de" href={`https://www.sajconnect.com/de${pagePath.replace(/^\/(de|en|pt-br)/, "") || ""}`} />
    <link rel="alternate" hreflang="en" href={`https://www.sajconnect.com/en${pagePath.replace(/^\/(de|en|pt-br)/, "") || ""}`} />
    <link rel="alternate" hreflang="pt-BR" href={`https://www.sajconnect.com/pt-br${pagePath.replace(/^\/(de|en|pt-br)/, "") || ""}`} />
    <link rel="alternate" hreflang="x-default" href={`https://www.sajconnect.com/de${pagePath.replace(/^\/(de|en|pt-br)/, "") || ""}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" />

    <script is:inline>
      // Apply theme before paint to avoid flash. Ohne gespeicherte Wahl folgt
      // die Seite der Systemeinstellung (prefers-color-scheme) — auch live,
      // wenn das Betriebssystem umschaltet. Re-applied after every
      // ClientRouter navigation (view-transition swap replaces <html>).
      (() => {
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const applyTheme = () => {
          let theme = null;
          try {
            const stored = localStorage.getItem("saj_theme");
            if (stored === "light" || stored === "dark") theme = stored;
          } catch (e) {
            /* storage unavailable */
          }
          document.documentElement.setAttribute("data-theme", theme || (media.matches ? "dark" : "light"));
        };
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
        media.addEventListener("change", applyTheme);
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-[var(--color-carbon)] text-[var(--color-text-on-carbon)]">
    {!Astro.props.hideHeader && <Header />}
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner client:idle locale={locale} />
    <RevealScript />
  </body>
</html>
