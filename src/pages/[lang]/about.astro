---
import Layout from "../../layouts/Layout.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { LOCALES, t, getDict, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

interface Diff {
  n: string;
  text: string;
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);
const diffs = getDict<Diff[]>(lang, "about.differentiators.items") ?? [];
---

<Layout title={tt("about.title")} description={tt("about.lead")}>
  <section class="surface-carbon relative overflow-hidden">
    <div class="container-prose pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">{tt("ui.chapter")} 02</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">SAJ Connect GmbH</p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">{tt("about.title")}</h1>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-12 gap-6 border-t border-[var(--color-hairline-dark)] pt-10 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("ui.lead")}</p>
        </div>
        <div class="col-span-12 md:col-span-7 space-y-6">
          <p class="lede">{tt("about.lead")}</p>
          <p class="text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">{tt("about.leadSecond")}</p>
        </div>
        <div class="hidden md:col-span-3 md:flex md:flex-col md:gap-6 md:border-l md:border-[var(--color-hairline-dark)] md:pl-6">
          <div>
            <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("ui.focus")}</p>
            <p class="mt-2 font-display text-base font-medium">Telco × Automotive × IoT</p>
          </div>
          <div>
            <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("ui.headquarter")}</p>
            <p class="mt-2 font-display text-base font-medium">Offenhausen, DE</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-carbon" style="background-color: var(--color-carbon-soft);">
    <div class="container-prose section">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-3">
          <p class="chapter-mark">{tt("ui.mission")}</p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h2 class="display-lg text-[var(--color-bone)]">
            <span class="text-[var(--color-saj-green-bright)]">„</span>{tt("about.mission.text")}<span class="text-[var(--color-saj-green-bright)]">"</span>
          </h2>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-carbon">
    <div class="container-prose section">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-3">
          <p class="chapter-mark">{tt("ui.differentiators")}</p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h2 class="display-lg text-[var(--color-bone)]">{tt("about.differentiators.title")}</h2>
        </div>
      </div>

      <ul class="mt-20 grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-2 lg:grid-cols-5">
        {diffs.map((d, idx) => {
          const isCobalt = idx % 2 === 0;
          const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
          const glowVar = isCobalt ? "--color-cobalt-glow" : "--color-saj-green-glow";
          return (
            <li class="group relative flex h-full flex-col bg-[var(--color-carbon)] p-7 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:p-8">
              <span
                class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                style={`background-color: var(${accentVar}); box-shadow: 0 0 12px var(${glowVar});`}
              ></span>
              <p class="text-sm leading-relaxed text-[var(--color-text-on-carbon-muted)] md:text-base">{d.text}</p>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <CtaBanner />
</Layout>
