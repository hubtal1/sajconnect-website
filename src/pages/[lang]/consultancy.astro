---
import Layout from "../../layouts/Layout.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { LOCALES, t, getDict, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

interface Item {
  title: string;
  text: string;
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);
const items = getDict<Item[]>(lang, "consultancy.items") ?? [];
---

<Layout title={tt("consultancy.title")} description={tt("consultancy.lead")}>
  <section class="surface-carbon mesh-cobalt noise relative overflow-hidden">
    <div class="container-prose pt-10 md:pt-12">
      <div class="flex items-center justify-between border-b border-[var(--color-hairline-dark)] pb-4 mono-label-sm text-[var(--color-text-on-carbon-faint)]">
        <span class="flex items-center gap-2">
          <span class="glow-dot"></span>
          <span class="text-[var(--color-saj-green-bright)]">{tt("ui.deepDive")} · 01</span>
        </span>
        <span class="hidden md:block">Concept to live operations</span>
        <span class="text-[var(--color-cobalt-light)]">Private 5G</span>
      </div>
    </div>

    <div class="container-prose pt-24 pb-20 md:pt-32 md:pb-28">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">01 / 03</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">Private 5G</p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">{tt("consultancy.title")}</h1>
          <p class="lede mt-10 max-w-[58ch]">
            {tt("consultancy.lead")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-carbon">
    <div class="container-prose pb-24">
      <div class="grid gap-px bg-[var(--color-hairline-dark)]">
        {items.map((item, idx) => (
          <article class="group grid grid-cols-12 gap-6 bg-[var(--color-carbon)] py-12 px-2 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:py-14 md:px-6">
            <div class="col-span-12 md:col-span-2">
              <p class:list={["font-display text-5xl font-medium leading-none tracking-tight transition-transform duration-500 group-hover:translate-x-1 md:text-6xl", idx % 2 === 0 ? "text-[var(--color-cobalt-light)]" : "text-[var(--color-saj-green-bright)]"]}>
                {String(idx + 1).padStart(2, "0")}
              </p>
            </div>
            <div class="col-span-12 md:col-span-10">
              <h2 class="display-md text-[var(--color-bone)]">{item.title}</h2>
              <p class="mt-5 max-w-[58ch] text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">
                {item.text}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>
