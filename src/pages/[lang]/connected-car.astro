---
import Layout from "../../layouts/Layout.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { LOCALES, t, getDict, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

interface Item {
  title: string;
  tag: string;
  text: string;
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);
const items = getDict<Item[]>(lang, "vehicle.items") ?? [];
---

<Layout title={tt("vehicle.title")} description={tt("vehicle.lead")}>
  <section class="surface-carbon mesh-dual noise relative overflow-hidden">
    <div class="container-prose pt-10 md:pt-12">
      <div class="flex items-center justify-between border-b border-[var(--color-hairline-dark)] pb-4 mono-label-sm text-[var(--color-text-on-carbon-faint)]">
        <span class="flex items-center gap-2">
          <span class="glow-dot"></span>
          <span class="text-[var(--color-saj-green-bright)]">{tt("ui.deepDive")} · 03</span>
        </span>
        <span class="hidden md:block">Connected Car · IVI · ECU</span>
        <span class="text-[var(--color-cobalt-light)]">Vehicle Platform</span>
      </div>
    </div>

    <div class="container-prose pt-24 pb-20 md:pt-32 md:pb-28">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">03 / 03</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">
            Connected Car &amp; IVI
          </p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">{tt("vehicle.title")}</h1>
          <p class="lede mt-10 max-w-[58ch]">
            {tt("vehicle.lead")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-carbon">
    <div class="container-prose section reveal">
      <div class="grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-2">
        {items.map((item, idx) => {
          const isCobalt = idx % 2 === 0;
          const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
          const glowVar = isCobalt ? "--color-cobalt-glow" : "--color-saj-green-glow";
          return (
            <article class="group relative bg-[var(--color-carbon)] p-8 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:p-12">
              <span
                class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                style={`background-color: var(${accentVar}); box-shadow: 0 0 12px var(${glowVar});`}
              ></span>
              <div class="flex items-baseline justify-between">
                <p class="mono-label-sm" style={`color: var(${accentVar});`}>{item.tag}</p>
                <span class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                  {String(idx + 1).padStart(2, "0")} / {String(items.length).padStart(2, "0")}
                </span>
              </div>
              <h2 class="display-md mt-10 text-[var(--color-bone)]">
                {item.title}
              </h2>
              <p class="mt-5 text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">
                {item.text}
              </p>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <CtaBanner />
</Layout>
