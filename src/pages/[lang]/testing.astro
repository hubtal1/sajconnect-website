---
import Layout from "../../layouts/Layout.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { LOCALES, t, getDict, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

interface Item {
  title: string;
  text: string;
}

interface Group {
  headline: string;
  items: Item[];
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);
const groups = getDict<Group[]>(lang, "testing.groups") ?? [];
---

<Layout title={tt("testing.title")} description={tt("testing.lead")}>
  <section class="surface-carbon relative overflow-hidden">
    <div class="container-prose pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">02 / 03</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">
            {tt("testing.chapterLabel")}
          </p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">
            {tt("testing.title")}
          </h1>
          <p class="lede mt-10 max-w-[58ch]">
            {tt("testing.lead")}
          </p>
        </div>
      </div>
    </div>
  </section>

  {groups.map((group, gIdx) => {
    const accent = gIdx === 0 ? "cobalt" : "green";
    const accentText = accent === "cobalt" ? "var(--color-cobalt-light)" : "var(--color-saj-green-bright)";
    const accentGlow = accent === "cobalt" ? "var(--color-cobalt-glow)" : "var(--color-saj-green-glow)";
    return (
      <section class="surface-carbon">
        <div class="container-prose section">
          <div class="grid grid-cols-12 gap-6 reveal">
            <div class="col-span-12 md:col-span-3">
              <p class="chapter-mark" style={`color: ${accentText};`}>
                <span class="block h-px w-6" style={`background-color: ${accentText};`}></span>
                0{gIdx + 1} / 0{groups.length}
              </p>
            </div>
            <div class="col-span-12 md:col-span-9">
              <h2 class="display-lg text-[var(--color-bone)]">
                {group.headline}
              </h2>
            </div>
          </div>

          <div class="mt-20 grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-2">
            {group.items.map((item, idx) => (
              <article class="group relative bg-[var(--color-carbon)] p-8 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:p-10">
                <span
                  class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                  style={`background-color: ${accentText}; box-shadow: 0 0 12px ${accentGlow};`}
                ></span>
                <div class="flex items-baseline justify-between">
                  <p class="mono-label-sm" style={`color: ${accentText};`}>
                    {String(idx + 1).padStart(2, "0")}
                  </p>
                  <span class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                    {String(idx + 1).padStart(2, "0")} / {String(group.items.length).padStart(2, "0")}
                  </span>
                </div>
                <h3 class="heading-card mt-8 text-[var(--color-bone)]">
                  {item.title}
                </h3>
                <p class="mt-5 text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">
                  {item.text}
                </p>
              </article>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <CtaBanner />
</Layout>
