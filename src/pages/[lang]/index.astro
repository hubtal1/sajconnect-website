---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import BlattGeltungsbereich from "../../components/BlattGeltungsbereich.astro";
import BlattLeistungen from "../../components/BlattLeistungen.astro";
import BlattVerfahren from "../../components/BlattVerfahren.astro";
import BlattNormen from "../../components/BlattNormen.astro";
import BlattVertrag from "../../components/BlattVertrag.astro";
import { LOCALES, t, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);
---

<Layout title={`${tt("site.name")} — ${tt("site.tagline")}`} description={tt("site.description")}>
  <Hero />
  <BlattGeltungsbereich />
  <BlattLeistungen />
  <BlattVerfahren />
  <BlattNormen />
  <BlattVertrag />
</Layout>
