---
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../../components/ContactForm.tsx";
import { LOCALES, t, type Locale } from "../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);

const responseLine = tt("ui.responseLine");
const formHeadline = tt("ui.sendMessage");
const directLabel = tt("ui.direct");
const responseLabel = tt("ui.responseTime");
---

<Layout title={tt("contact.title")} description={tt("contact.lead")}>
  <section class="surface-carbon relative overflow-hidden">
    <div class="container-prose pt-16 pb-12 md:pt-24 md:pb-16">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">{tt("ui.chapter")} 04</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">{tt("nav.contact")}</p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">{tt("contact.title")}</h1>
          <p class="lede mt-10 max-w-[58ch]">
            {tt("contact.lead")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-carbon">
    <div class="container-prose pb-24 md:pb-32">
      <div class="grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-12">
        <!-- Form column -->
        <div class="md:col-span-8 bg-[var(--color-carbon)] p-8 md:p-12">
          <div class="flex items-baseline justify-between">
            <p class="mono-label text-[var(--color-cobalt-light)]">{tt("ui.form")}</p>
            <span class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">01 / 02</span>
          </div>
          <h2 class="display-md mt-6 text-[var(--color-bone)]">{formHeadline}</h2>
          <p class="mt-4 max-w-[55ch] text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">
            {responseLine}
          </p>
          <div class="mt-10">
            <ContactForm client:load locale={lang} />
          </div>
        </div>

        <!-- Direct column -->
        <aside class="md:col-span-4 bg-[var(--color-carbon)] p-8 md:p-12">
          <div class="flex items-baseline justify-between">
            <p class="mono-label text-[var(--color-saj-green-bright)]">{directLabel}</p>
            <span class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">02 / 02</span>
          </div>

          <div class="mt-10 space-y-10">
            <div>
              <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                {tt("contact.office")}
              </p>
              <p class="mt-3 text-base leading-relaxed text-[var(--color-bone)]">
                SAJ Connect GmbH<br />
                Egensbach 310<br />
                91238 Offenhausen<br />
                Deutschland
              </p>
            </div>

            <div>
              <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                {responseLabel}
              </p>
              <p class="mt-3 flex items-center gap-2 text-base text-[var(--color-bone)]">
                <span class="glow-dot"></span>
                <span>&lt; 24h</span>
              </p>
            </div>

          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
