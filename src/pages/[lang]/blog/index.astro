---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import { LOCALES, t, localizedPath, contentSlug, type Locale } from "../../../i18n/utils";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const tt = t(lang);

const posts = await getCollection("blog", ({ data }) => !data.draft && data.locale === lang);
posts.sort((a, b) => +b.data.publishedAt - +a.data.publishedAt);

const dateLocale = lang === "de" ? "de-DE" : lang === "pt-br" ? "pt-BR" : "en-US";
---

<Layout title={tt("blog.title")} description={tt("blog.lead")}>
  <section class="surface-carbon relative overflow-hidden">
    <div class="container-prose pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="grid grid-cols-12 gap-6 reveal">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">Blog</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">{tt("ui.insights")}</p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">{tt("blog.title")}</h1>
          <p class="lede mt-10 max-w-[58ch]">
            {tt("blog.lead")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="surface-carbon">
    <div class="container-prose pb-24 md:pb-32">
      {posts.length === 0 && (
        <div class="border-t border-[var(--color-hairline-dark)] py-16 text-center">
          <p class="mono-label text-[var(--color-text-on-carbon-faint)]">{tt("blog.noPostsLabel")}</p>
          <p class="mt-4 lede max-w-[40ch] mx-auto">
            {tt("blog.noPosts")}
          </p>
        </div>
      )}

      <ul class="border-t border-[var(--color-hairline-dark)]">
        {posts.map((post, idx) => {
          const isCobalt = idx % 2 === 0;
          const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
          return (
            <li class="border-b border-[var(--color-hairline-dark)]">
              <a
                href={localizedPath(lang, `/blog/${contentSlug(post.id)}`)}
                class="group relative grid grid-cols-12 gap-6 py-10 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:py-14"
              >
                <span
                  class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
                  style={`background-color: var(${accentVar}); box-shadow: 0 0 12px var(${isCobalt ? "--color-cobalt-glow" : "--color-saj-green-glow"});`}
                ></span>

                <div class="col-span-12 md:col-span-2">
                  <p class="mono-label-sm" style={`color: var(${accentVar});`}>
                    {String(idx + 1).padStart(2, "0")} / {String(posts.length).padStart(2, "0")}
                  </p>
                  <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">
                    {new Date(post.data.publishedAt).toLocaleDateString(dateLocale, {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>
                </div>

                <div class="col-span-12 md:col-span-8">
                  <h2 class="display-md text-[var(--color-bone)] transition-colors duration-300 group-hover:text-[var(--color-cobalt-light)]">
                    {post.data.title}
                  </h2>
                  <p class="mt-4 max-w-[58ch] text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">
                    {post.data.description}
                  </p>
                  {post.data.tags.length > 0 && (
                    <div class="mt-5 flex flex-wrap gap-3">
                      {post.data.tags.map((tag) => (
                        <span class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                          # {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>

                <div class="col-span-12 md:col-span-2 md:text-right">
                  <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                    {tt("blog.by")}
                  </p>
                  <p class="mt-3 text-sm text-[var(--color-text-on-carbon-muted)]">{post.data.author}</p>
                  <span class="arrow-link mt-6 inline-flex transition-all duration-300 group-hover:gap-3">
                    {tt("ui.readArticle")} →
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
</Layout>
