---
import { getLocaleFromUrl, t, getDict, localizedPath, type Locale } from "../i18n/utils";

interface Domain {
  title: string;
  tag: string;
  description: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const domains = getDict<Domain[]>(locale, "services.domains") ?? [];

const exploreCta = tt("services.exploreAll");
---

<section class="surface-carbon mesh-green relative overflow-hidden">
  <div class="container-prose section">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-3">
        <p class="chapter-mark">{tt("ui.chapter")} 03</p>
        <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">{tt("ui.capabilities")}</p>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg text-[var(--color-bone)]">
          {tt("services.gridTagline")}
        </h2>
        <p class="lede mt-8 max-w-[58ch]">
          {tt("services.lead")}
        </p>
      </div>
    </div>

    <!-- Compact teaser grid: just titles + tags, no descriptions
         (the full description grid lives on /services) -->
    <ul class="mt-16 grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-2 lg:grid-cols-4">
      {domains.map((d, idx) => {
        const isCobalt = idx % 2 === 0;
        const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
        const glowVar = isCobalt ? "--color-cobalt-glow" : "--color-saj-green-glow";
        return (
          <li class="group relative bg-[var(--color-carbon)] p-6 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:p-7">
            <span
              class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
              style={`background-color: var(${accentVar}); box-shadow: 0 0 8px var(${glowVar});`}
            ></span>
            <div class="flex items-baseline justify-between">
              <span class="mono-label-sm" style={`color: var(${accentVar});`}>{d.tag}</span>
              <span class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                {String(idx + 1).padStart(2, "0")}
              </span>
            </div>
            <h3 class="mt-6 text-lg font-medium leading-snug tracking-tight text-[var(--color-bone)]">
              {d.title}
            </h3>
          </li>
        );
      })}
    </ul>

    <div class="mt-12 flex flex-col items-start gap-6 border-t border-[var(--color-hairline-dark)] pt-10 md:flex-row md:items-end md:justify-between">
      <div class="max-w-[60ch]">
        <p class="chapter-mark text-[var(--color-amber)]">
          {tt("ui.outlook")}
        </p>
        <h3 class="mt-4 display-md text-[var(--color-bone)]">
          {tt("services.outroHeadline")}
        </h3>
        <p class="mt-4 text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">
          {tt("services.outroSub")}
        </p>
      </div>
      <a href={localizedPath(locale, "/services")} class="btn btn-primary shrink-0">
        {exploreCta} →
      </a>
    </div>
  </div>
</section>
