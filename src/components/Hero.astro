---
import { getLocaleFromUrl, t, getDict, localizedPath, type Locale } from "../i18n/utils";

interface SpecRow {
  k: string;
  v: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const specRows = getDict<SpecRow[]>(locale, "dossier.hero.spec.rows") ?? [];
const verbs = getDict<string[]>(locale, "dossier.hero.verbs") ?? [];
---

<section class="text-[var(--color-text-on-carbon)]">
  <div class="container-prose pb-14 pt-16 md:pb-20 md:pt-24">
    <div class="w-fit max-w-full">
      <h1 class="font-display font-bold leading-[1.02] tracking-[-0.012em]" style="font-size: clamp(2.25rem, 6vw, 5.25rem);">
        <span class="mb-5 block font-sans text-[0.34em] font-normal italic leading-none tracking-normal text-[var(--color-text-on-carbon-muted)]">
          {tt("dossier.hero.kicker")}
        </span>
        {verbs.map((verb, idx) => (
          <span class="block">
            <sup class:list={[
              "mr-3 align-top font-mono text-[0.26em] font-medium",
              idx === 2 ? "text-[var(--color-saj-green-bright)]" : "text-[var(--color-cobalt-light)]",
            ]}>{String(idx + 1).padStart(2, "0")}</sup>{verb}
          </span>
        ))}
      </h1>

      <!-- Maßkette: vermisst die Headline — das stille Signature-Element -->
      <svg class="mt-9 h-10 w-full" viewBox="0 0 640 40" fill="none" aria-hidden="true" preserveAspectRatio="none">
        <path class="masskette-line" d="M1 10 V38 M639 10 V38" />
        <path class="masskette-line masskette-draw" d="M1 26 H639" />
        <path d="M1 26 L14 21.5 V30.5 Z M639 26 L626 21.5 V30.5 Z" fill="var(--color-text-on-carbon)" />
        <text class="masskette-label" x="320" y="14" text-anchor="middle" font-size="10">
          {tt("dossier.hero.masskette")}
        </text>
      </svg>
    </div>

    <p class="lede mt-10 max-w-[58ch]">
      {tt("dossier.hero.sub")}
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-6">
      <a
        href={localizedPath(locale, "/contact")}
        class="inline-flex items-center justify-center bg-[var(--color-cobalt)] px-7 py-3.5 font-sans text-[0.9375rem] font-bold tracking-[0.01em] text-white transition-colors duration-150 hover:bg-[var(--color-cobalt-light)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-cobalt)]"
      >
        {tt("dossier.hero.ctaPrimary")}
      </a>
      <a
        href={localizedPath(locale, "/services")}
        class="mono-label-sm text-[var(--color-text-on-carbon-muted)] underline decoration-[var(--color-hairline-dark)] decoration-1 underline-offset-4 transition-colors duration-150 hover:text-[var(--color-cobalt-light)] hover:decoration-[var(--color-cobalt-light)]"
      >
        {tt("dossier.hero.ctaSecondary")}
      </a>
    </div>

    <!-- Faktenzeile: offene Schlüssel/Wert-Paare, keine Box -->
    <dl class="mt-16 flex flex-wrap gap-x-12 gap-y-6 border-t border-[var(--color-hairline-dark)] pt-6 md:mt-20">
      {specRows.map((row) => (
        <div>
          <dt class="text-[0.8125rem] font-bold text-[var(--color-text-on-carbon-faint)]">{row.k}</dt>
          <dd class="mono-spec mt-1 text-[var(--color-text-on-carbon)]">{row.v}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
