---
import SignalCanvas from "./SignalCanvas.tsx";
import { getLocaleFromUrl, t, getDict, localizedPath, type Locale } from "../i18n/utils";

interface Pillar {
  label: string;
  text: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const pillars = getDict<Pillar[]>(locale, "home.pillars") ?? [];
---

<section class="surface-carbon mesh-dual noise relative isolate overflow-hidden">
  <!-- animated network -->
  <div class="absolute inset-0 z-0">
    <SignalCanvas client:load />
  </div>

  <!-- gradient mask for text legibility -->
  <div
    class="pointer-events-none absolute inset-0 z-[1]"
    style="background: linear-gradient(180deg, rgba(7,8,11,0.65) 0%, rgba(7,8,11,0.45) 50%, rgba(7,8,11,0.85) 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10">
    <!-- top index bar -->
    <div class="container-prose pt-10 md:pt-12">
      <div class="flex items-center justify-between border-b border-[var(--color-hairline-dark)] pb-4 mono-label-sm text-[var(--color-text-on-carbon-faint)]">
        <span class="flex items-center gap-2">
          <span class="glow-dot"></span>
          <span class="text-[var(--color-saj-green-bright)]">{tt("ui.live")} · {tt("ui.operational")}</span>
        </span>
        <span class="hidden md:block">SAJ Connect GmbH · Egensbach 310 · 91238 Offenhausen · DE</span>
        <span class="text-[var(--color-cobalt-light)]">N 49.4441° · E 11.3921°</span>
      </div>
    </div>

    <!-- hero content -->
    <div class="container-prose pt-24 pb-20 md:pt-32 md:pb-28">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-2">
          <p class="chapter-mark">{tt("ui.chapter")} 01</p>
          <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">
            {tt("home.hero.eyebrow")}
          </p>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h1 class="display-xl text-[var(--color-bone)]">
            {tt("home.hero.headline")}
          </h1>
        </div>
      </div>

      <div class="mt-16 grid grid-cols-12 gap-6 border-t border-[var(--color-hairline-dark)] pt-10">
        <div class="col-span-12 md:col-span-2">
          <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("ui.lead")}</p>
        </div>
        <div class="col-span-12 md:col-span-7">
          <p class="lede max-w-[58ch]">
            {tt("home.hero.sub")}
          </p>
          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a href={localizedPath(locale, "/contact")} class="btn btn-primary">
              {tt("home.hero.ctaPrimary")} →
            </a>
            <a href={localizedPath(locale, "/services")} class="btn btn-ghost">
              {tt("home.hero.ctaSecondary")}
            </a>
          </div>
        </div>
        <div class="hidden md:col-span-3 md:flex md:flex-col md:gap-6 md:border-l md:border-[var(--color-hairline-dark)] md:pl-6">
          <div>
            <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("ui.founded")}</p>
            <p class="mt-2 font-display text-base font-medium">{locale === "de" ? "Dezember 2025" : locale === "pt-br" ? "Dezembro de 2025" : "December 2025"}</p>
          </div>
          <div>
            <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("ui.focus")}</p>
            <p class="mt-2 font-display text-base font-medium">Telco × Automotive × IoT</p>
          </div>
          <div>
            <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{locale === "de" ? "Reichweite" : locale === "pt-br" ? "Alcance" : "Reach"}</p>
            <p class="mt-2 font-display text-base font-medium">{locale === "de" ? "Globales Ökosystem" : locale === "pt-br" ? "Ecossistema global" : "Global ecosystem"}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- pillars: kinetic table -->
    <div class="container-prose pb-20">
      <div class="grid grid-cols-2 border-y border-[var(--color-hairline-dark)] md:grid-cols-4">
        {pillars.map((p, idx) => (
          <div
            class:list={[
              "group relative p-7 transition-colors duration-300 hover:bg-[var(--color-carbon-elev)] md:p-8",
              idx > 0 && "md:border-l md:border-[var(--color-hairline-dark)]",
              idx === 1 && "border-l border-[var(--color-hairline-dark)]",
              idx >= 2 && "border-t border-[var(--color-hairline-dark)] md:border-t-0",
            ]}
          >
            <div class="flex items-baseline justify-between">
              <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
                {String(idx + 1).padStart(2, "0")}
              </p>
              <span
                class:list={[
                  "block h-1.5 w-1.5 rounded-full opacity-40 transition-all duration-500 group-hover:opacity-100",
                  idx % 2 === 0 ? "bg-[var(--color-cobalt-light)]" : "bg-[var(--color-saj-green-bright)]",
                ]}
                style={idx % 2 === 0 ? "box-shadow: 0 0 12px var(--color-cobalt-glow);" : "box-shadow: 0 0 12px var(--color-saj-green-glow);"}
              ></span>
            </div>
            <p class="mt-5 font-display text-3xl font-medium tracking-tight md:text-4xl">
              {p.label}
            </p>
            <p class="mt-4 text-sm leading-relaxed text-[var(--color-text-on-carbon-muted)]">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
