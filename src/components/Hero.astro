---
import { getLocaleFromUrl, t, getDict, localizedPath, type Locale } from "../i18n/utils";

interface SpecRow {
  k: string;
  v: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const specRows = getDict<SpecRow[]>(locale, "dossier.hero.spec.rows") ?? [];
const verbs = getDict<string[]>(locale, "dossier.hero.verbs") ?? [];
---

<section class="text-[var(--color-text-on-carbon)]">
  <div class="container-prose pb-14 pt-16 md:pb-20 md:pt-24">
    <div class="lg:grid lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:items-center lg:gap-16">
      <div>
    <div class="w-fit max-w-full">
      <h1 class="font-display font-bold leading-[1.02] tracking-[-0.012em]" style="font-size: clamp(2.25rem, 6vw, 5.25rem);">
        <span class="mb-3 block font-sans text-[0.5em] font-bold leading-none tracking-[-0.01em] text-[var(--color-text-on-carbon)]">
          {tt("dossier.hero.kicker")}
        </span>
        {verbs.map((verb) => (
          <span class="block">{verb}</span>
        ))}
      </h1>

      <!-- Maßkette: vermisst die Headline — das stille Signature-Element -->
      <svg class="mt-9 h-10 w-full" viewBox="0 0 640 40" fill="none" aria-hidden="true" preserveAspectRatio="none">
        <path class="masskette-line" d="M1 10 V38 M639 10 V38" />
        <path class="masskette-line masskette-draw" d="M1 26 H639" />
        <path d="M1 26 L14 21.5 V30.5 Z M639 26 L626 21.5 V30.5 Z" fill="var(--color-text-on-carbon)" />
        <text class="masskette-label" x="320" y="14" text-anchor="middle" font-size="10">
          {tt("dossier.hero.masskette")}
        </text>
      </svg>
    </div>

    <p class="lede mt-10 max-w-[58ch]">
      {tt("dossier.hero.sub")}
    </p>

    <div class="mt-10">
      <a
        href={localizedPath(locale, "/contact")}
        class="inline-flex items-center justify-center bg-[var(--color-cobalt)] px-7 py-3.5 font-sans text-[0.9375rem] font-bold tracking-[0.01em] text-white transition-colors duration-150 hover:bg-[var(--color-cobalt-light)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-cobalt)]"
      >
        {tt("dossier.hero.ctaPrimary")}
      </a>
    </div>
      </div>

      <!-- Funkzellen-Raster: Bildsprache der Mobilfunk-Netzplanung -->
      <div class="hidden lg:block" aria-hidden="true">
        <svg class="mx-auto h-auto w-full max-w-[480px]" viewBox="0 0 440 380" fill="none" aria-hidden="true"><path d="M270.0,190.0 L245.0,233.3 L195.0,233.3 L170.0,190.0 L195.0,146.7 L245.0,146.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M348.0,145.0 L323.0,188.3 L273.0,188.3 L248.0,145.0 L273.0,101.7 L323.0,101.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M348.0,235.0 L323.0,278.3 L273.0,278.3 L248.0,235.0 L273.0,191.7 L323.0,191.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M270.0,99.9 L245.0,143.2 L195.0,143.2 L170.0,99.9 L195.0,56.6 L245.0,56.6 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M270.0,280.1 L245.0,323.4 L195.0,323.4 L170.0,280.1 L195.0,236.8 L245.0,236.8 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M192.0,145.0 L167.0,188.3 L117.0,188.3 L92.0,145.0 L117.0,101.7 L167.0,101.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M192.0,235.0 L167.0,278.3 L117.0,278.3 L92.0,235.0 L117.0,191.7 L167.0,191.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M426.0,190.0 L401.0,233.3 L351.0,233.3 L326.0,190.0 L351.0,146.7 L401.0,146.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M114.0,190.0 L89.0,233.3 L39.0,233.3 L14.0,190.0 L39.0,146.7 L89.0,146.7 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M426.0,99.9 L401.0,143.2 L351.0,143.2 L326.0,99.9 L351.0,56.6 L401.0,56.6 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M192.0,325.1 L167.0,368.4 L117.0,368.4 L92.0,325.1 L117.0,281.8 L167.0,281.8 Z" stroke="var(--color-hairline-dark)" stroke-width="1.2"/><path d="M270.0,190.0 L245.0,233.3 L195.0,233.3 L170.0,190.0 L195.0,146.7 L245.0,146.7 Z" stroke="var(--color-cobalt-light)" stroke-width="1.8"/><circle cx="220" cy="190" r="5" fill="var(--color-cobalt-light)"/><circle cx="298" cy="144.9666790032092" r="5" fill="var(--color-saj-green-bright)"/><circle cx="142" cy="235.0333209967908" r="3.5" stroke="var(--color-cobalt-light)" stroke-width="1.5"/></svg>
      </div>
    </div>

    <!-- Faktenzeile: offene Schlüssel/Wert-Paare, keine Box -->
    <dl class="mt-16 flex flex-wrap gap-x-12 gap-y-6 border-t border-[var(--color-hairline-dark)] pt-6 md:mt-20">
      {specRows.map((row) => (
        <div>
          <dt class="text-[0.8125rem] font-bold text-[var(--color-text-on-carbon-faint)]">{row.k}</dt>
          <dd class="mono-spec mt-1 text-[var(--color-text-on-carbon)]">{row.v}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
