---
import { getLocaleFromUrl, t, getDict, type Locale } from "../i18n/utils";

interface Step {
  title: string;
  text: string;
  outcome: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const steps = getDict<Step[]>(locale, "home.approach.steps") ?? [];
---

<section class="surface-carbon">
  <div class="container-prose section">
    <div class="grid grid-cols-12 gap-6 reveal">
      <div class="col-span-12 md:col-span-3">
        <p class="chapter-mark">{tt("ui.chapter")} 04</p>
        <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">{tt("home.approach.label")}</p>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg text-[var(--color-bone)]">{tt("home.approach.headline")}</h2>
        <p class="lede mt-8 max-w-[58ch]">{tt("home.approach.sub")}</p>
      </div>
    </div>

    <div class="mt-16 grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-3">
      {steps.map((step, idx) => {
        const isCobalt = idx % 2 === 0;
        const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
        return (
          <div class="group relative bg-[var(--color-carbon)] p-8 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:p-10">
            <span
              class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
              style={`background-color: var(${accentVar});`}
            ></span>
            <p class="mono-label-sm" style={`color: var(${accentVar});`}>
              {String(idx + 1).padStart(2, "0")} / {String(steps.length).padStart(2, "0")}
            </p>
            <h3 class="heading-card mt-6 text-[var(--color-bone)]">{step.title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-[var(--color-text-on-carbon-muted)]">{step.text}</p>
            <div class="mt-8 border-t border-[var(--color-hairline-dark)] pt-5">
              <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">{tt("home.approach.outcomeLabel")}</p>
              <p class="mt-2 text-sm font-medium leading-relaxed text-[var(--color-bone)]">{step.outcome}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
