---
import DossierBlatt from "./DossierBlatt.astro";
import { getLocaleFromUrl, t, getDict, localizedPath, type Locale } from "../i18n/utils";

interface Model {
  title: string;
  text: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const models = getDict<Model[]>(locale, "services.engagement.models") ?? [];
const lineStyles = [
  "border-top: 3px solid var(--color-text-on-carbon);",
  "border-top: 3px dashed var(--color-text-on-carbon);",
  "border-top: 7px double var(--color-text-on-carbon);",
];
---

<DossierBlatt nr="5.0" title={tt("dossier.sections.vertragsmodelle")} blatt="06/06" id="vertragsmodelle">
  <p class="lede mt-10 max-w-[58ch]">{tt("services.engagement.sub")}</p>

  <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-12">
    {models.map((model, idx) => (
      <div style={lineStyles[idx]} class="pt-4">
        <h3 class="heading-card mt-2.5 text-[var(--color-text-on-carbon)]">{model.title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-on-carbon-muted)]">{model.text}</p>
      </div>
    ))}
  </div>

  <!-- Abbinder: Kontakt, offen gesetzt -->
  <div class="mt-16 flex flex-col gap-6 border-t border-[var(--color-hairline-dark)] pt-10 sm:flex-row sm:items-center sm:justify-between">
    <a
      href={localizedPath(locale, "/contact")}
      class="inline-flex items-center justify-center self-start bg-[var(--color-cobalt)] px-7 py-3.5 font-sans text-[0.9375rem] font-bold tracking-[0.01em] text-white transition-colors duration-150 hover:bg-[var(--color-cobalt-light)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-cobalt)]"
    >
      {tt("dossier.hero.ctaPrimary")}
    </a>
    <span class="text-sm text-[var(--color-text-on-carbon-faint)]">SAJ Connect GmbH · Connectivity is our passion</span>
  </div>
</DossierBlatt>
