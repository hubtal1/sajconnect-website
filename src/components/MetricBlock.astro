---
import { getLocaleFromUrl, t, type Locale } from "../i18n/utils";

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);

const metrics = [
  { value: "8", label: tt("metrics.domains"), suffix: "" },
  { value: "10", label: tt("metrics.testing"), suffix: "+" },
  { value: "6", label: tt("metrics.connectedCar"), suffix: "" },
  { value: tt("metrics.global"), label: tt("metrics.partners"), suffix: "" },
];
---

<section class="surface-carbon">
  <div class="container-prose section-tight">
    <div class="grid grid-cols-2 gap-px bg-[var(--color-hairline-dark)] md:grid-cols-4">
      {metrics.map((m, idx) => {
        const isCobalt = idx % 2 === 0;
        const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
        const glowVar = isCobalt ? "--color-cobalt-glow" : "--color-saj-green-glow";
        return (
          <div class="group relative bg-[var(--color-carbon)] p-8 transition-colors duration-500 hover:bg-[var(--color-carbon-soft)] md:p-10">
            <span
              class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
              style={`background-color: var(${accentVar}); box-shadow: 0 0 12px var(${glowVar});`}
            ></span>

            <p class="mono-label-sm text-[var(--color-text-on-carbon-faint)]">
              {String(idx + 1).padStart(2, "0")} / {String(metrics.length).padStart(2, "0")}
            </p>

            <p
              class:list={[
                "mt-6 font-display text-4xl font-medium leading-none tracking-tight text-[var(--color-bone)] transition-colors duration-500 md:text-5xl",
                isCobalt ? "group-hover:text-[var(--color-cobalt-light)]" : "group-hover:text-[var(--color-saj-green-bright)]",
              ]}
            >
              {m.value}{m.suffix && <span style={`color: var(${accentVar});`}>{m.suffix}</span>}
            </p>

            <span
              class="mt-6 block h-px w-8 transition-all duration-500 group-hover:w-16"
              style={`background-color: var(${accentVar});`}
            ></span>

            <p class="mt-5 text-sm leading-relaxed text-[var(--color-text-on-carbon-muted)]">
              {m.label}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>
