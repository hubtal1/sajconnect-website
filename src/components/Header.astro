---
import LanguageSwitcher from "./LanguageSwitcher.tsx";
import ThemeToggle from "./ThemeToggle.tsx";
import Logo from "./Logo.astro";
import { getLocaleFromUrl, t, localizedPath, type Locale } from "../i18n/utils";

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);

const services = [
  { label: tt("nav.services"), href: localizedPath(locale, "/services") },
  { label: tt("nav.consultancy"), href: localizedPath(locale, "/consultancy") },
  { label: tt("nav.testing"), href: localizedPath(locale, "/testing") },
  { label: tt("nav.vehicle"), href: localizedPath(locale, "/connected-car") },
];

const nav = [
  { label: tt("nav.about"), href: localizedPath(locale, "/about") },
  { label: tt("nav.careers"), href: localizedPath(locale, "/careers") },
  { label: tt("nav.blog"), href: localizedPath(locale, "/blog") },
  { label: tt("nav.contact"), href: localizedPath(locale, "/contact") },
];
---

<header class="sticky top-0 z-40 border-b border-[var(--color-hairline-dark)] bg-[var(--color-carbon)]/85 text-[var(--color-text-on-carbon)] backdrop-blur-md">
  <div class="container-prose flex h-20 items-center justify-between gap-4">
    <a href={localizedPath(locale, "/")} class="group flex items-center transition-opacity hover:opacity-80" aria-label="SAJ Connect — Home">
      <Logo width={180} withTagline={true} />
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm">
      <details class="group relative">
        <summary class="flex cursor-pointer list-none items-center gap-1 text-[var(--color-text-on-carbon-muted)] hover:text-[var(--color-cobalt-light)] transition-colors">
          {tt("nav.services")}
          <svg width="9" height="9" viewBox="0 0 10 10" fill="none" class="transition-transform group-open:rotate-180">
            <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </summary>
        <ul class="absolute left-0 mt-3 min-w-[240px] border border-[var(--color-hairline-dark)] bg-[var(--color-carbon)] py-2 backdrop-blur-md">
          {services.map((s) => (
            <li>
              <a href={s.href} class="block px-5 py-2.5 text-sm text-[var(--color-text-on-carbon-muted)] hover:bg-[var(--color-carbon-soft)] hover:text-[var(--color-cobalt-light)] transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </details>

      {nav.map((item) => (
        <a href={item.href} class="text-[var(--color-text-on-carbon-muted)] hover:text-[var(--color-cobalt-light)] transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle client:idle />
      <LanguageSwitcher client:idle currentLocale={locale} pathname={Astro.url.pathname} />
      <a href={localizedPath(locale, "/contact")} class="ml-1 hidden md:inline-flex btn btn-primary !py-2 !px-4 text-sm">
        {tt("home.hero.ctaPrimary")}
      </a>
    </div>
  </div>

  <details class="lg:hidden border-t border-[var(--color-hairline-dark)]">
    <summary class="container-prose flex items-center justify-between py-3 cursor-pointer text-sm">
      Menu
    </summary>
    <nav class="container-prose flex flex-col gap-1 pb-5 text-sm">
      <p class="mt-3 mono-label-sm text-[var(--color-text-on-carbon-faint)]">
        {tt("nav.services")}
      </p>
      {services.map((s) => (
        <a href={s.href} class="py-2 text-[var(--color-text-on-carbon-muted)] hover:text-[var(--color-cobalt-light)]">
          {s.label}
        </a>
      ))}
      <p class="mt-4 mono-label-sm text-[var(--color-text-on-carbon-faint)]">
        Company
      </p>
      {nav.map((item) => (
        <a href={item.href} class="py-2 text-[var(--color-text-on-carbon-muted)] hover:text-[var(--color-cobalt-light)]">
          {item.label}
        </a>
      ))}
    </nav>
  </details>
</header>
