---
import DossierBlatt from "./DossierBlatt.astro";
import { getLocaleFromUrl, t, getDict, localizedPath, type Locale } from "../i18n/utils";

interface Domain {
  title: string;
  tag: string;
  description: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const domains = getDict<Domain[]>(locale, "services.domains") ?? [];

// Sprachneutrale Fachsubstanz je Domäne — Bänder, Normen, Schnittstellen.
const BANDS = [
  "n77/n78 · 3,5 GHz · FR2",
  "GSMA SGP.21/22",
  "NB-IoT · LTE-M",
  "NTN · Ka-Band",
  "3GPP Rel-20+",
  "API · MQTT",
  "5,9 GHz ITS",
  "Device-to-Cloud",
];
---

<DossierBlatt nr="2.0" title={tt("dossier.sections.leistungsverzeichnis")} blatt="03/06" id="leistungsverzeichnis">
  <p class="lede mt-10 max-w-[58ch]">{tt("services.lead")}</p>

  <ol class="mt-10">
    {domains.map((d, idx) => (
      <li
        class:list={[
          "py-5 md:grid md:grid-cols-[1.1fr_11.5rem_1.6fr] md:gap-x-8",
          idx > 0 && "border-t border-[var(--color-hairline-dark)]",
        ]}
      >
        <span class="block font-bold leading-snug text-[var(--color-text-on-carbon)]">{d.title}</span>
        <span class="mono-spec mt-1 block text-[0.8125rem] text-[var(--color-text-on-carbon-muted)] md:mt-0.5">{BANDS[idx]}</span>
        <span class="mt-2 block max-w-[60ch] text-sm leading-relaxed text-[var(--color-text-on-carbon-muted)] md:mt-0.5">{d.description}</span>
      </li>
    ))}
  </ol>

  <div class="mt-8">
    <a
      href={localizedPath(locale, "/services")}
      class="mono-label-sm text-[var(--color-text-on-carbon-muted)] underline decoration-[var(--color-hairline-dark)] decoration-1 underline-offset-4 transition-colors duration-150 hover:text-[var(--color-cobalt-light)] hover:decoration-[var(--color-cobalt-light)]"
    >
      {tt("services.exploreAll")}
    </a>
  </div>
</DossierBlatt>
