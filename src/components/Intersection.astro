---
import { getLocaleFromUrl, t, getDict, type Locale } from "../i18n/utils";

interface Item {
  title: string;
  text: string;
}

const locale: Locale = getLocaleFromUrl(Astro.url);
const tt = t(locale);
const items = getDict<Item[]>(locale, "home.differentiators.items") ?? [];
---

<section class="surface-carbon relative overflow-hidden" style="background-color: var(--color-carbon-soft);">
  <!-- dual cobalt/green gradient at top -->
  <div class="hairline-dual"></div>

  <div class="container-prose section">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-3">
        <p class="chapter-mark">{tt("ui.chapter")} 02</p>
        <p class="mt-3 mono-spec text-[var(--color-text-on-carbon-muted)]">
          {tt("home.intersection.headline")}
        </p>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display-lg text-[var(--color-bone)]">
          {tt("home.differentiators.headline")}
        </h2>
        <p class="lede mt-8 max-w-[58ch]">
          {tt("home.intersection.sub")}
        </p>
      </div>
    </div>

    <div class="mt-20 grid gap-px bg-[var(--color-hairline-dark)] md:grid-cols-2">
      {items.map((item, idx) => {
        const isCobalt = idx % 2 === 0;
        const accentVar = isCobalt ? "--color-cobalt-light" : "--color-saj-green-bright";
        const glowVar = isCobalt ? "--color-cobalt-glow" : "--color-saj-green-glow";
        return (
          <article
            class="group relative p-8 transition-colors duration-500 hover:bg-[var(--color-carbon-elev)] md:p-12"
            style="background-color: var(--color-carbon-soft);"
          >
            <span
              class="absolute left-0 top-0 h-px w-0 transition-all duration-700 group-hover:w-full"
              style={`background-color: var(${accentVar}); box-shadow: 0 0 12px var(${glowVar});`}
            ></span>
            <div class="flex items-baseline justify-between">
              <span class="mono-label" style={`color: var(${accentVar});`}>
                {String(idx + 1).padStart(2, "0")} / {String(items.length).padStart(2, "0")}
              </span>
              <span
                class="block h-px w-12 transition-all duration-500 group-hover:w-24"
                style={`background-color: var(--color-hairline-dark);`}
              ></span>
            </div>
            <h3 class="heading-card mt-8 text-[var(--color-bone)]">{item.title}</h3>
            <p class="mt-4 text-base leading-relaxed text-[var(--color-text-on-carbon-muted)]">{item.text}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>
